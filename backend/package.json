{
  "name": "dacan-erp-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@clerk/backend": "^1.20.0",
    "@prisma/client": "^6.8.2",
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prisma": "^6.8.2",
    "tsx": "^4.19.3",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
